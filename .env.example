# Testar sem banco (dados em memória no app)
EXPO_PUBLIC_MOCK=1

# Backend próprio (PostgreSQL no seu PC): API Node em server/
EXPO_PUBLIC_API_URL=http://192.168.0.10:4000/api

# Ou Supabase na nuvem (sem EXPO_PUBLIC_API_URL)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
